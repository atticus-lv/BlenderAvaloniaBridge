<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:models="using:BlenderAvaloniaBridge.Sample.Models"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.BlenderObjectsPageView"
             x:DataType="viewModels:BlenderObjectsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.BlenderObjectsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Blender Objects" />
          <TextBlock Classes="page-subtitle"
                     Text="Browse scene objects and edit a few core RNA properties." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Objects"
                Padding="14,8"
                Command="{Binding RefreshObjectsCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto"
              RowSpacing="10">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Scene Objects" />
          <ComboBox Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding Objects}"
                    SelectedItem="{Binding SelectedObject, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:BlenderObjectListItem">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Text="{Binding Label}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding ObjectType}"
                             Classes="body-subtle" />
                </Grid>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Reference" />
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text="{Binding SelectedReferenceText}"
                     Classes="reference-text" />
        </Grid>
      </Border>

      <Border Classes="panel-card surface">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto"
              RowSpacing="12">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Name" />
          <TextBox Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding ObjectName, Mode=TwoWay}"
                   LostFocus="OnNameLostFocus"
                   KeyDown="OnNameKeyDown" />

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Location" />
          <Grid Grid.Row="1"
                Grid.Column="1"
                ColumnDefinitions="*,*,*"
                ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding LocationX, Mode=TwoWay}"
                     LostFocus="OnLocationLostFocus"
                     KeyDown="OnLocationKeyDown" />
            <TextBox Grid.Column="1"
                     Text="{Binding LocationY, Mode=TwoWay}"
                     LostFocus="OnLocationLostFocus"
                     KeyDown="OnLocationKeyDown" />
            <TextBox Grid.Column="2"
                     Text="{Binding LocationZ, Mode=TwoWay}"
                     LostFocus="OnLocationLostFocus"
                     KeyDown="OnLocationKeyDown" />
          </Grid>
        </Grid>
      </Border>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
