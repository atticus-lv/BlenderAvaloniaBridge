<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:models="using:BlenderAvaloniaBridge.Sample.Models"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.OperatorsPageView"
             x:DataType="viewModels:OperatorsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.OperatorsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Operators" />
          <TextBlock Classes="page-subtitle"
                     Text="Preview poll state and run a few common operator workflows." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Objects"
                Padding="14,8"
                Command="{Binding RefreshObjectsCommand}" />
        <Button Grid.Column="2"
                Content="Refresh Poll"
                Padding="14,8"
                Command="{Binding RefreshPollCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto"
              RowSpacing="10">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Selection" />
          <ComboBox Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding Objects}"
                    SelectedItem="{Binding SelectedObject, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="models:BlenderObjectListItem">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBlock Text="{Binding Label}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding ObjectType}"
                             Classes="body-subtle" />
                </Grid>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Reference" />
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text="{Binding SelectedReferenceText}"
                     Classes="reference-text" />
        </Grid>
      </Border>

      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Add Cube" />
            <TextBlock Text="{Binding AddCubePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <Button Content="mesh.primitive_cube_add"
                    Command="{Binding AddCubeCommand}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Duplicate" />
            <TextBlock Text="{Binding DuplicatePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <Button Content="object.duplicate_move"
                    Command="{Binding DuplicateCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="View Selected" />
            <TextBlock Text="{Binding ViewSelectedPollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <Button Content="view3d.view_selected"
                    Command="{Binding ViewSelectedCommand}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Delete Selected" />
            <TextBlock Text="{Binding DeletePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <Button Content="object.delete"
                    Command="{Binding DeleteSelectedCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
