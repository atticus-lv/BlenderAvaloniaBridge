<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.OperatorsPageView"
             x:DataType="viewModels:OperatorsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.OperatorsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Operator Playground" />
          <TextBlock Classes="page-subtitle"
                     Text="Preview poll state for the current Blender context object and run a few common operators." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Context Object"
                Padding="14,8"
                Command="{Binding RefreshObjectsCommand}" />
        <Button Grid.Column="2"
                Content="Refresh Poll"
                Padding="14,8"
                Command="{Binding RefreshPollCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto"
              RowSpacing="10">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Source" />
          <TextBlock Grid.Row="0"
                     Grid.Column="1"
                     Text="bpy.context.object"
                     Classes="reference-text" />

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Reference" />
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Text="{Binding SelectedReferenceText}"
                     Classes="reference-text" />
        </Grid>
      </Border>

      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Add Cube" />
            <TextBlock Text="{Binding AddCubePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <TextBlock Text="Adds a new mesh cube using Blender's default operator context."
                       TextWrapping="Wrap"
                       Classes="body-subtle" />
            <Button Content="mesh.primitive_cube_add"
                    Command="{Binding AddCubeCommand}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Duplicate" />
            <TextBlock Text="{Binding DuplicatePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <TextBlock Text="Duplicates the current context object with an explicit selection override."
                       TextWrapping="Wrap"
                       Classes="body-subtle" />
            <Button Content="object.duplicate_move"
                    Command="{Binding DuplicateCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="View Selected" />
            <TextBlock Text="{Binding ViewSelectedPollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <TextBlock Text="Frames the current context object in the active 3D view when polling allows it."
                       TextWrapping="Wrap"
                       Classes="body-subtle" />
            <Button Content="view3d.view_selected"
                    Command="{Binding ViewSelectedCommand}" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Delete Selected" />
            <TextBlock Text="{Binding DeletePollText}"
                       TextWrapping="Wrap"
                       Classes="body-muted" />
            <TextBlock Text="Deletes the current context object through the standard object.delete operator."
                       TextWrapping="Wrap"
                       Classes="body-subtle" />
            <Button Content="object.delete"
                    Command="{Binding DeleteSelectedCommand}" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
