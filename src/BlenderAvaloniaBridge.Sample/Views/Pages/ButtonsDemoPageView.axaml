<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.ButtonsDemoPageView"
             x:DataType="viewModels:ButtonsDemoPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.ButtonsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="18">
      <StackPanel Spacing="4">
        <TextBlock Classes="page-title"
                   Text="Buttons + Checkbox" />
        <TextBlock Classes="page-subtitle"
                   Text="A small control showcase page separated from the Blender bridge page." />
      </StackPanel>

      <Border Classes="panel-card emphasis"
              Padding="18"
              CornerRadius="14">
        <StackPanel Spacing="14">
          <TextBlock Classes="section-title"
                     Text="Actions" />

          <WrapPanel Orientation="Horizontal"
                     ItemSpacing="10"
                     LineSpacing="10">
            <Button Content="Primary Action"
                    Padding="16,10"
                    Command="{Binding TriggerPrimaryActionCommand}" />
            <Button Content="Secondary Action"
                    Padding="16,10"
                    Command="{Binding TriggerSecondaryActionCommand}" />
          </WrapPanel>

          <StackPanel Spacing="10">
            <CheckBox Content="Enable primary option"
                      IsChecked="{Binding IsPrimaryOptionEnabled, Mode=TwoWay}" />
            <CheckBox Content="Enable secondary option"
                      IsChecked="{Binding IsSecondaryOptionEnabled, Mode=TwoWay}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="panel-card soft"
              Padding="18"
              CornerRadius="14">
        <StackPanel Spacing="8">
          <TextBlock Classes="section-title"
                     Text="Activity" />
          <TextBlock Text="{Binding ActivityText}"
                     TextWrapping="Wrap"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
