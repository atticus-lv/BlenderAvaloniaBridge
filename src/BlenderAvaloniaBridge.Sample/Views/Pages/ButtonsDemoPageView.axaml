<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.ButtonsDemoPageView"
             x:DataType="viewModels:ButtonsDemoPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.ButtonsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="18">
      <StackPanel Spacing="4">
        <TextBlock Classes="page-title"
                   Text="Buttons + Checkbox" />
        <TextBlock Classes="page-subtitle"
                   Text="A small control showcase page separated from the Blender bridge page." />
      </StackPanel>

      <Border Classes="panel-card emphasis"
              Padding="18"
              CornerRadius="14">
        <StackPanel Spacing="14">
          <TextBlock Classes="section-title"
                     Text="Actions" />

          <WrapPanel Orientation="Horizontal"
                     ItemSpacing="10"
                     LineSpacing="10">
            <Button Content="Primary Action"
                    Padding="16,10"
                    Command="{Binding TriggerPrimaryActionCommand}" />
            <Button Content="Secondary Action"
                    Padding="16,10"
                    Command="{Binding TriggerSecondaryActionCommand}" />
          </WrapPanel>

          <StackPanel Spacing="10">
            <CheckBox Content="Enable primary option"
                      IsChecked="{Binding IsPrimaryOptionEnabled, Mode=TwoWay}" />
            <CheckBox Content="Enable secondary option"
                      IsChecked="{Binding IsSecondaryOptionEnabled, Mode=TwoWay}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Classes="panel-card surface"
              Padding="18"
              CornerRadius="14">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="14"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
              RowSpacing="14">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Notes" />
          <TextBox Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding NotesText, Mode=TwoWay}"
                   PlaceholderText="Write a short note..." />

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Quality" />
          <ComboBox Grid.Row="1"
                    Grid.Column="1"
                    ItemsSource="{Binding QualityOptions}"
                    SelectedItem="{Binding SelectedQuality, Mode=TwoWay}" />

          <TextBlock Grid.Row="2"
                     Classes="field-label"
                     Text="Automation" />
          <ToggleSwitch Grid.Row="2"
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        OffContent="Off"
                        OnContent="On"
                        IsChecked="{Binding IsAutomationEnabled, Mode=TwoWay}" />

          <TextBlock Grid.Row="3"
                     Classes="field-label"
                     Text="Intensity" />
          <StackPanel Grid.Row="3"
                      Grid.Column="1"
                      Spacing="8">
            <Slider Minimum="0"
                    Maximum="100"
                    Value="{Binding Intensity, Mode=TwoWay}" />
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Value="{Binding Intensity}" />
          </StackPanel>

          <TextBlock Grid.Row="4"
                     Classes="field-label"
                     Text="Value" />
          <TextBlock Grid.Row="4"
                     Grid.Column="1"
                     Text="{Binding Intensity, StringFormat='{}{0:0}%'}"
                     Classes="body-muted" />
        </Grid>
      </Border>

      <Border Classes="panel-card soft"
              Padding="18"
              CornerRadius="14">
        <StackPanel Spacing="8">
          <TextBlock Classes="section-title"
                     Text="Activity" />
          <TextBlock Text="{Binding ActivityText}"
                     TextWrapping="Wrap"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
