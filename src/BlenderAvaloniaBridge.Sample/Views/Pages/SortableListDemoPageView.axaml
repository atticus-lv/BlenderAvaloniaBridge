<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:models="using:BlenderAvaloniaBridge.Sample.Models"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.SortableListDemoPageView"
             x:DataType="viewModels:SortableListDemoPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.SortableListPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="18">
      <StackPanel Spacing="4">
        <TextBlock Classes="page-title"
                   Text="ListBox Drag Sort" />
        <TextBlock Classes="page-subtitle"
                   Text="A side-by-side sample with a simple ScrollViewer list on the left and a drag-and-drop sorting example on the right." />
      </StackPanel>

      <Grid ColumnDefinitions="1.25*,*"
            ColumnSpacing="14">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Task Library" />
            <TextBlock Classes="page-subtitle"
                       Text="A simple scrollable pool of tasks for reference." />
            <ScrollViewer Height="380"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="6">
                <ItemsControl ItemsSource="{Binding LibraryItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SortableListItem">
                      <Border Padding="10"
                              Background="#FF0F172A"
                              BorderBrush="#223148"
                              BorderThickness="1"
                              CornerRadius="12">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Foreground="#FFF8FAFC" />
                          <TextBlock Text="{Binding Description}"
                                     TextWrapping="Wrap"
                                     FontSize="12"
                                     Classes="body-muted" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card emphasis"
                CornerRadius="14">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Execution Queue" />
            <TextBlock Classes="page-subtitle"
                       Text="Drag to reorder the next four tasks." />
            <ListBox x:Name="SortableListBox"
                     Height="336"
                     ItemsSource="{Binding SortableItems}"
                     Background="Transparent"
                     BorderThickness="0">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="2" />
                <Setter Property="RenderTransform">
                  <Setter.Value>
                    <TransformOperations>translate(0px, 0px)</TransformOperations>
                    </Setter.Value>
                  </Setter>
                </Style>
                <Style Selector="ListBoxItem:dragging">
                  <Setter Property="Opacity" Value="0.78" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:SortableListItem">
                  <Border Margin="0,0,0,4"
                          Padding="8,6"
                          Background="#FF0F172A"
                          BorderBrush="#223148"
                          BorderThickness="1"
                          CornerRadius="10"
                          Opacity="1">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                      <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#FFF8FAFC" />
                      </StackPanel>

                      <Border Grid.Column="1"
                              Width="24"
                              Height="30"
                              CornerRadius="7"
                              Background="#1D4ED8"
                              Tag="DragHandle"
                              PointerPressed="OnDragHandlePressed">
                        <TextBlock Text="::"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFFFF" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="panel-card soft"
              Padding="18"
              CornerRadius="14">
        <TextBlock Text="{Binding StatusText}"
                   TextWrapping="Wrap"
                   Classes="body-muted" />
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
