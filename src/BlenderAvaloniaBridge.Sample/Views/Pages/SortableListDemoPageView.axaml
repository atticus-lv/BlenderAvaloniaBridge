<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:BlenderAvaloniaBridge.Sample.ViewModels"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.SortableListDemoPageView"
             x:DataType="viewModels:SortableListDemoPageViewModel">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="18">
      <StackPanel Spacing="4">
        <TextBlock Text="ListBox Drag Sort"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#FFF8FAFC" />
        <TextBlock Text="Drag the left handle of any item to reorder the demo list."
                   Foreground="#FF94A3B8" />
      </StackPanel>

      <Border Padding="14"
              Background="#FF162033"
              BorderBrush="#223148"
              BorderThickness="1"
              CornerRadius="14">
        <ListBox x:Name="SortableListBox"
                 Height="380"
                 ItemsSource="{Binding Items}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="RenderTransform">
                <Setter.Value>
                  <TransformOperations>translate(0px, 0px)</TransformOperations>
                </Setter.Value>
              </Setter>
            </Style>
            <Style Selector="ListBoxItem:dragging">
              <Setter Property="Opacity" Value="0.78" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="viewModels:SortableListItemViewModel">
              <Border Margin="0,0,0,6"
                      Padding="10"
                      Background="#FF0F172A"
                      BorderBrush="#223148"
                      BorderThickness="1"
                      CornerRadius="12"
                      Opacity="1">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                  <Border Width="28"
                          Height="42"
                          CornerRadius="8"
                          Background="#1D4ED8"
                          Tag="DragHandle"
                          PointerPressed="OnDragHandlePressed">
                    <TextBlock Text="::"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#FFFFFFFF" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              Spacing="2">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FFF8FAFC" />
                    <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#FFCBD5E1" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Border Padding="18"
              Background="#FF101826"
              BorderBrush="#223148"
              BorderThickness="1"
              CornerRadius="14">
        <TextBlock Text="{Binding StatusText}"
                   TextWrapping="Wrap"
                   Foreground="#FFE2E8F0" />
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
