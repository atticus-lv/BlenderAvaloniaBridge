<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:models="using:BlenderAvaloniaBridge.Sample.Models"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.CollectionsPageView"
             x:DataType="viewModels:CollectionsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.CollectionsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Collections" />
          <TextBlock Classes="page-subtitle"
                     Text="Inspect collection hierarchies and linked object membership." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Collections"
                Padding="14,8"
                Command="{Binding RefreshCollectionsCommand}" />
      </Grid>

      <Border Classes="panel-card surface">
        <StackPanel Spacing="10">
          <TextBlock Classes="section-title"
                     Text="Scene Tree" />
          <TextBlock Classes="body-subtle"
                     Text="Collections stay expandable, and linked objects appear directly under their owning collection." />
          <TreeView ItemsSource="{Binding CollectionTreeRoots}"
                    SelectedItem="{Binding SelectedCollectionNode, Mode=TwoWay}"
                    Height="420">
            <TreeView.Styles>
              <Style Selector="TreeViewItem"
                     x:DataType="models:CollectionTreeItem">
                <Setter Property="IsExpanded"
                        Value="{CompiledBinding IsExpanded, Mode=TwoWay}" />
                <Setter Property="FocusAdorner"
                        Value="{x:Null}" />
              </Style>
            </TreeView.Styles>
            <TreeView.DataTemplates>
              <TreeDataTemplate DataType="models:CollectionTreeItem"
                                ItemsSource="{Binding Children}"
                                x:DataType="models:CollectionTreeItem">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10"
                      Margin="2,0">
                  <PathIcon Data="{Binding Icon}"
                            Classes="tree-node-icon"
                            Classes.collection="{Binding IsCollection}"
                            Classes.object="{Binding IsObject}"
                            Width="16"
                            Height="16" />

                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Text="{Binding Name}"
                             Classes="tree-node-title" />
                </Grid>
              </TreeDataTemplate>
            </TreeView.DataTemplates>
          </TreeView>
        </StackPanel>
      </Border>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
