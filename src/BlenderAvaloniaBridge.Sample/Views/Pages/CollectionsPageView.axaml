<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:bridge="clr-namespace:BlenderAvaloniaBridge;assembly=BlenderAvaloniaBridge.Core"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.CollectionsPageView"
             x:DataType="viewModels:CollectionsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.CollectionsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Collections" />
          <TextBlock Classes="page-subtitle"
                     Text="Inspect collection hierarchies and linked object membership." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Collections"
                Padding="14,8"
                Command="{Binding RefreshCollectionsCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12">
          <TextBlock Classes="field-label"
                     Text="Collection" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding Collections}"
                    SelectedItem="{Binding SelectedCollection, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="bridge:RnaItemRef">
                <TextBlock Text="{Binding Name}"
                           Foreground="#FFF8FAFC" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>
      </Border>

      <Grid ColumnDefinitions="*,*"
            ColumnSpacing="12">
        <Border Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Child Collections" />
            <ListBox ItemsSource="{Binding ChildCollections}"
                     Height="260">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="bridge:RnaItemRef">
                  <TextBlock Text="{Binding Name}"
                             Classes="body-muted" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Classes="panel-card surface">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-title"
                       Text="Objects" />
            <ListBox ItemsSource="{Binding CollectionObjects}"
                     Height="260">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="bridge:RnaItemRef">
                  <TextBlock Text="{Binding Name}"
                             Classes="body-muted" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>
      </Grid>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
