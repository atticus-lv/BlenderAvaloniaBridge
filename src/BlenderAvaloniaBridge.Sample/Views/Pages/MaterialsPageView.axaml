<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:bridge="clr-namespace:BlenderAvaloniaBridge;assembly=BlenderAvaloniaBridge.Core"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.MaterialsPageView"
             x:DataType="viewModels:MaterialsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.MaterialsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="4">
          <TextBlock Classes="page-title"
                     Text="Materials" />
          <TextBlock Classes="page-subtitle"
                     Text="Browse materials, create new ones, and observe list updates." />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh Materials"
                Padding="14,8"
                Command="{Binding RefreshMaterialsCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="10">
          <TextBlock Classes="field-label"
                     Text="Create" />
          <TextBox Grid.Column="1"
                   Text="{Binding NewMaterialName, Mode=TwoWay}" />
          <Button Grid.Column="2"
                  Content="New Material"
                  Padding="14,8"
                  Command="{Binding CreateMaterialCommand}" />
        </Grid>
      </Border>

      <Border Classes="panel-card surface">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              RowDefinitions="Auto,Auto,Auto"
              RowSpacing="12">
          <TextBlock Grid.Row="0"
                     Classes="field-label"
                     Text="Material" />
          <ComboBox Grid.Row="0"
                    Grid.Column="1"
                    ItemsSource="{Binding Materials}"
                    SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="bridge:RnaItemRef">
                <TextBlock Text="{Binding Name}"
                           Foreground="#FFF8FAFC" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Row="1"
                     Classes="field-label"
                     Text="Name" />
          <TextBox Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding MaterialName, Mode=TwoWay}"
                   LostFocus="OnNameLostFocus"
                   KeyDown="OnNameKeyDown" />

          <TextBlock Grid.Row="2"
                     Classes="field-label"
                     Text="Use Nodes" />
          <CheckBox Grid.Row="2"
                    Grid.Column="1"
                    Content="Enable node tree"
                    IsChecked="{Binding UseNodes, Mode=TwoWay}" />
        </Grid>
      </Border>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
