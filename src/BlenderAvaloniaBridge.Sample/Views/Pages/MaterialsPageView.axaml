<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="using:BlenderAvaloniaBridge.Sample.Design"
             xmlns:models="using:BlenderAvaloniaBridge.Sample.Models"
             xmlns:viewModels="using:BlenderAvaloniaBridge.Sample.ViewModels.Pages"
             x:Class="BlenderAvaloniaBridge.Sample.Views.Pages.MaterialsPageView"
             x:DataType="viewModels:MaterialsPageViewModel"
             d:DataContext="{x:Static design:SampleDesignData.MaterialsPage}"
             d:DesignWidth="1040"
             d:DesignHeight="760"
             mc:Ignorable="d">
  <ScrollViewer>
    <StackPanel Margin="22"
                Spacing="14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="12">
        <StackPanel Spacing="2">
          <TextBlock Classes="page-title"
                     Text="Materials" />
        </StackPanel>

        <Button Grid.Column="1"
                Content="Refresh"
                Padding="14,8"
                Command="{Binding RefreshMaterialsCommand}" />
      </Grid>

      <Border Classes="panel-card emphasis">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="10"
              VerticalAlignment="Center">
          <TextBlock Classes="field-label"
                     VerticalAlignment="Center"
                     Text="Create" />
          <TextBox Grid.Column="1"
                   Text="{Binding NewMaterialName, Mode=TwoWay}"
                   PlaceholderText="Material" />
          <Button Grid.Column="2"
                  Content="New Material"
                  Padding="14,8"
                  Command="{Binding CreateMaterialCommand}" />
          <Button Grid.Column="3"
                  Padding="14,8"
                  Content="Refresh Selected Preview"
                  Command="{Binding RefreshSelectedPreviewCommand}" />
        </Grid>
      </Border>

      <Border Classes="panel-card surface">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="14">
          <TextBlock Classes="section-title"
                     Text="Library" />

          <ListBox Grid.Row="1"
                   Classes="material-library"
                   Background="Transparent"
                   BorderThickness="0"
                   ItemsSource="{Binding Materials}"
                   SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"
                           ItemWidth="188"
                           ItemHeight="228" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:MaterialLibraryItem">
                <Border Classes="material-tile">
                  <Grid RowDefinitions="138,Auto,Auto"
                        RowSpacing="10">
                    <Border Classes="material-preview-frame">
                      <Grid>
                        <Image Source="{Binding Thumbnail}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding HasThumbnail}" />

                        <StackPanel IsVisible="{Binding ShowPlaceholder}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                          <TextBlock Classes="material-placeholder-initials"
                                     HorizontalAlignment="Center"
                                     Text="{Binding DisplayInitials}" />
                          <TextBlock Classes="body-subtle"
                                     HorizontalAlignment="Center"
                                     Text="Preview pending" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="{Binding DisplayName}"
                               TextWrapping="Wrap"
                               Classes="material-tile-title" />

                    <TextBlock Grid.Row="2"
                               Text="{Binding KindLabel}"
                               Classes="body-subtle" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Classes="panel-card status">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding StatusText}"
                     Classes="status-highlight" />
          <TextBlock Text="{Binding BridgeStatusText}"
                     Classes="body-muted" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
