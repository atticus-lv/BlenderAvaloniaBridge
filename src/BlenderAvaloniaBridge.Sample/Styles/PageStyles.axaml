<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="TextBlock.page-title">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#FFF8FAFC" />
  </Style>

  <Style Selector="TextBlock.page-subtitle">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="#FF94A3B8" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#FFF8FAFC" />
  </Style>

  <Style Selector="TextBlock.field-label">
    <Setter Property="Foreground" Value="#FFCBD5E1" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.body-muted">
    <Setter Property="Foreground" Value="#FFE2E8F0" />
  </Style>

  <Style Selector="TextBlock.body-subtle">
    <Setter Property="Foreground" Value="#FF94A3B8" />
  </Style>

  <Style Selector="TextBlock.status-highlight">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#FFFDE68A" />
  </Style>

  <Style Selector="TextBlock.reference-text">
    <Setter Property="Foreground" Value="#FFFDE68A" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="Border.panel-card">
    <Setter Property="BorderBrush" Value="#223148" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.panel-card.emphasis">
    <Setter Property="Background" Value="#FF172033" />
  </Style>

  <Style Selector="Border.panel-card.surface">
    <Setter Property="Background" Value="#FF111B2D" />
  </Style>

  <Style Selector="Border.panel-card.status">
    <Setter Property="Background" Value="#FF1D2432" />
    <Setter Property="BorderBrush" Value="#253449" />
  </Style>

  <Style Selector="Border.panel-card.soft">
    <Setter Property="Background" Value="#FF101826" />
  </Style>

  <Style Selector="ListBox.material-library">
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="ListBox.material-library > ListBoxItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0,0,14,14" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Border.material-tile">
    <Setter Property="Background" Value="#FF0E1728" />
    <Setter Property="BorderBrush" Value="#1F3047" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="ListBox.material-library > ListBoxItem:pointerover Border.material-tile">
    <Setter Property="Background" Value="#FF15233A" />
    <Setter Property="BorderBrush" Value="#33527A" />
  </Style>

  <Style Selector="ListBox.material-library > ListBoxItem:selected Border.material-tile">
    <Setter Property="Background" Value="#FF182944" />
    <Setter Property="BorderBrush" Value="#5AB0FF" />
    <Setter Property="BoxShadow" Value="0 10 28 0 #22000000" />
  </Style>

  <Style Selector="Border.material-preview-frame">
    <Setter Property="Background" Value="#FF0A101B" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderBrush" Value="#21344D" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Border.material-hero-frame">
    <Setter Property="Background" Value="#FF0A101B" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderBrush" Value="#2B4568" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="260" />
  </Style>

  <Style Selector="TextBlock.material-tile-title">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="#FFF8FAFC" />
  </Style>

  <Style Selector="TextBlock.material-placeholder-initials">
    <Setter Property="FontSize" Value="34" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#FFD7EAFE" />
  </Style>

  <Style Selector="Border.tree-node-card">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="6,4" />
  </Style>

  <Style Selector="TreeViewItem:pointerover Border.tree-node-card">
    <Setter Property="Background" Value="#14233A" />
  </Style>

  <Style Selector="TreeViewItem:selected Border.tree-node-card">
    <Setter Property="Background" Value="#183154" />
    <Setter Property="BoxShadow" Value="0 0 0 1 #5AB0FF" />
  </Style>

  <Style Selector="PathIcon.tree-node-icon">
    <Setter Property="Foreground" Value="#8FB7DE" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="PathIcon.tree-node-icon.collection">
    <Setter Property="Foreground" Value="#7FB3E6" />
  </Style>

  <Style Selector="PathIcon.tree-node-icon.object">
    <Setter Property="Foreground" Value="#7DC7A0" />
  </Style>

  <Style Selector="TreeViewItem:selected PathIcon.tree-node-icon">
    <Setter Property="Foreground" Value="#D8ECFF" />
  </Style>

  <Style Selector="TextBlock.tree-node-title">
    <Setter Property="Foreground" Value="#FFF8FAFC" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>
</Styles>
